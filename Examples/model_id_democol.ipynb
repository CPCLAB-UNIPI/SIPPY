    "    tsample= tsample,\n",
    "    SS_fixed_order=fix_ordr,\n",
    "    SS_max_order=max_order,\n",
    "    SS_orders=ss_orders,\n",
    "    SS_threshold=SS_threshold,\n",
    "    IC=IC,\n",
    "    SS_f=TH,\n",
    "    SS_D_required=req_D,\n",
    "    SS_A_stability=force_A_stable\n",
    "    )"
